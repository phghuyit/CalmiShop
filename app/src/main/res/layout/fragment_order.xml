<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:layout_height="match_parent" android:layout_width="match_parent"
android:id="@+id/main"
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:orientation="vertical"
    >
    <com.google.android.flexbox.FlexboxLayout
        android:layout_height="50dp"
        android:layout_width="match_parent"
        app:justifyContent="space_around"
        app:alignItems="center"
        >
        <View
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đơn Hàng"
            android:fontFamily="@font/lorabold"
            android:textSize="20sp"
            />
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_cart"
            android:id="@+id/toCart"
            />
    </com.google.android.flexbox.FlexboxLayout>
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        >
        <LinearLayout
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:layout_marginVertical="10dp"
            >
            <TextView
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Tất Cả"
                android:gravity="center"
                android:layout_gravity="center"
                android:background="@drawable/btn"
                android:layout_marginVertical="10dp"
                android:textColor="@color/white"
                android:layout_marginHorizontal="5dp"
                android:textSize="16sp"
                android:padding="15dp"
                />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Đang giao hàng"
                android:gravity="center"
                android:layout_gravity="center"
                android:background="@drawable/btn"
                android:layout_marginVertical="10dp"
                android:textColor="@color/white"
                android:layout_marginHorizontal="5dp"
                android:textSize="16sp"
                android:padding="15dp"
                />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Đã Hoàn Thành"
                android:gravity="center"
                android:layout_gravity="center"
                android:background="@drawable/btn"
                android:layout_marginVertical="10dp"
                android:textColor="@color/white"
                android:layout_marginHorizontal="5dp"
                android:textSize="16sp"
                android:padding="15dp"
                />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Đã Hủy"
                android:gravity="center"
                android:layout_gravity="center"
                android:background="@drawable/btn"
                android:layout_marginVertical="10dp"
                android:textColor="@color/white"
                android:layout_marginHorizontal="5dp"
                android:textSize="16sp"
                android:padding="15dp"
                />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Trả Hàng"
                android:gravity="center"
                android:layout_gravity="center"
                android:background="@drawable/btn"
                android:layout_marginVertical="10dp"
                android:textColor="@color/white"
                android:layout_marginHorizontal="5dp"
                android:textSize="16sp"
                android:padding="15dp"
                />
        </LinearLayout>
    </HorizontalScrollView>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="15dp">
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >
            <include layout="@layout/item_order_detail1"/>
            <include layout="@layout/item_order_detail2"/>
            <include layout="@layout/item_order_detail3"/>
        </LinearLayout>>
    </ScrollView>
</LinearLayout>