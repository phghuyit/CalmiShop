<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="10dp"
    android:orientation="vertical"
    android:id="@+id/main"
    >
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_arrow_left"
        android:layout_gravity="start"
        android:layout_marginStart="5dp"
        android:layout_marginTop="15dp"
        android:id="@+id/backBtn"
        />
    <LinearLayout
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:gravity="center|top"
        >
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/logo_create_pass"
            android:layout_gravity="center"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xin Chàooooo!"
            android:textSize="20sp"
            android:fontFamily="@font/lorabold"
            android:textColor="#606060"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhập mật khẩu mới nè"
            android:textSize="23sp"
            android:fontFamily="@font/lorabold"
            android:textColor="#303030"
            />
        <androidx.cardview.widget.CardView
            android:layout_height="wrap_content"
            android:layout_width="300dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="10dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            >
            <LinearLayout android:layout_height="match_parent"
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:padding="20dp"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mật Khẩu"
                    />
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Calmi@123"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xác Nhận Mật Khẩu"
                    />
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Calmi@123"/>

                <TextView
                    android:layout_width="230dp"
                    android:layout_height="45dp"
                    android:text="Đặt Lại Mật Khẩu Mới"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:background="@drawable/btn"
                    android:textColor="@color/white"
                    android:id="@+id/regisBtn"
                    android:layout_marginVertical="20dp"
                    />


            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>

