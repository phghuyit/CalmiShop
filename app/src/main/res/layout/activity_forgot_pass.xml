<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:layout_height="match_parent" android:layout_width="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/main">
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_arrow_left"
        android:layout_gravity="start"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="15dp"
        android:id="@+id/backBtn"
        />

    <ImageView
        android:layout_width="168dp"
        android:layout_height="190dp"
        android:layout_gravity="center"
        android:src="@drawable/logo_forgot_pass" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quên Mật Khẩu"
        android:textSize="39sp"
        android:fontFamily="@font/lorabold"
        android:textColor="#303030"
        android:layout_gravity="center"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vui lòng điền số điện thoại hoặc email"
        android:textSize="17sp"
        android:textColor="#ff4545"
        android:layout_gravity="center"
        />
    <LinearLayout
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:gravity="left"
        android:layout_marginStart="20dp"
        >
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:src="@drawable/ic_email"/>
        <EditText
            android:id="@+id/emailId"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:hint="calmishop@maill.com"
            android:inputType="textEmailAddress"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vẫn chưa nhập được mã? "
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginVertical="10dp"
            android:textColor="#808080"
            android:textSize="19sp"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gửi lại liền"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginVertical="10dp"
            android:textSize="19sp"
            android:id="@+id/signUpBtn"
            android:textColor="#2454f8"
            />
    </LinearLayout>
    <TextView
        android:layout_width="330dp"
        android:layout_height="55dp"
        android:text="Tiếp theo"
        android:layout_gravity="center"
        android:gravity="center"
        android:background="@drawable/btn"
        android:textColor="@color/white"
        android:id="@+id/toCreatePassBtn"
        android:layout_marginVertical="20dp"
        android:textSize="22sp"
        />
</LinearLayout>